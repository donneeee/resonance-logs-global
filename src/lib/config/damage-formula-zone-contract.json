      "appliesTo": ["luckyExpectedValue", "luckyStrikeDamage", "luckyEffectDamage"],
      "formulaBuckets": ["luck-proc", "generic-dmg"],
      "luckyTerms": ["luckyDamagePct", "luckyFinalDamagePct", "luckEntryDamageScaling", "luckStatDamageScaling"],
      "runtimeTerms": ["luckyDamagePct", "luckyEffectDamagePct", "genericDamagePct"],
