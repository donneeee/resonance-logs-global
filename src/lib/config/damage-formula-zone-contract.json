      "appliesTo": ["skillDamage", "luckyStrikeDamage", "luckyEffectDamage"],
      "formulaBuckets": ["final-dmg"],
      "runtimeTerms": ["finalDamagePct"],
      "contributionMath": "multiplicative-zone-share",
      "captureStatus": "classifier-gap"
    },
    {
      "id": "seasonDamage",
      "order": 90,
      "label": "Season damage zone",
      "formula": "1 + SeasonDamageMultiplier",
      "appliesTo": ["skillDamage", "luckyStrikeDamage", "luckyEffectDamage"],
      "formulaBuckets": ["season-dmg"],
      "runtimeTerms": ["seasonDamagePct"],
      "contributionMath": "multiplicative-zone-share",
      "captureStatus": "classifier-gap"
    },
    {
      "id": "seasonSuppression",
      "order": 100,
      "label": "Season suppression zone",
      "formula": "1 + SeasonSuppression",
      "appliesTo": ["skillDamage", "luckyStrikeDamage", "luckyEffectDamage"],
      "formulaBuckets": ["season-suppression"],
      "runtimeTerms": ["seasonSuppressionPct"],
      "contributionMath": "multiplicative-zone-share",
      "captureStatus": "classifier-gap"
    },
    {
      "id": "luckyChance",
      "order": 110,
      "label": "Lucky chance",
      "formula": "LuckyChance",
      "appliesTo": ["luckyExpectedValue"],
      "formulaBuckets": ["luck-proc"],
      "luckyTerms": ["luckChancePct", "luckyChancePct", "luckStatPct", "guaranteedLucky"],
      "runtimeTerms": ["isLucky", "luckyChancePct"],
