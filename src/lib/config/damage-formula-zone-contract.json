      "label": "Lucky multiplier",
      "formula": "0.4 + 0.25 * LuckyChance",
      "appliesTo": ["luckyExpectedValue", "luckyStrikeDamage", "luckyEffectDamage"],
      "formulaBuckets": ["luck-proc"],
      "luckyTerms": ["luckyMultiplierPct", "luckToLuckyScaling", "luckStatDamageScaling"],
      "runtimeTerms": ["luckyMultiplier"],
